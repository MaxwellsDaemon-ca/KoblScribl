---
import "../styles/site-parallax.css";

interface Props {
  title: string;
  description?: string;
  pageClass?: string;
}

const {
  title,
  description = "Kobold keep many scribls. Some shiny, some messy, some bite back.",
  pageClass = "",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />

    <title>{title} | KoblScribl</title>

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:site_name" content="KoblScribl" />
    <meta property="og:type" content="website" />
  </head>

  <body class={pageClass}>
    <div class="site-parallax" aria-hidden="true">
      <div class="site-parallax__layer site-parallax__layer--base"></div>
      <div class="site-parallax__layer site-parallax__layer--gold"></div>
      <div class="site-parallax__layer site-parallax__layer--blue"></div>
      <div class="site-parallax__layer site-parallax__layer--vignette"></div>
    </div>

    <header class="site-header">
      <div class="site-header-inner">
        <h1><a href="/">KoblScribl</a></h1>

        <nav class="site-nav" aria-label="Main navigation">
          <a href="/">Home</a>
          <a href="/works">Scribls!</a>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <script is:inline>
      (() => {
        /**
         * Keeps the decorative backdrop moving cheaply with requestAnimationFrame,
         * while fully respecting the reader's reduced-motion preference.
         */
        const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)");

        if (prefersReducedMotion.matches) {
          document.documentElement.style.setProperty("--parallax-y", "0px");
          document.documentElement.style.setProperty("--parallax-soft-y", "0px");
          return;
        }

        let ticking = false;

        const updateParallax = () => {
          const scrollY = window.scrollY || window.pageYOffset || 0;
          document.documentElement.style.setProperty("--parallax-y", `${scrollY * -0.12}px`);
          document.documentElement.style.setProperty("--parallax-soft-y", `${scrollY * 0.06}px`);
          ticking = false;
        };

        const requestUpdate = () => {
          if (ticking) return;

          window.requestAnimationFrame(updateParallax);
          ticking = true;
        };

        updateParallax();
        window.addEventListener("scroll", requestUpdate, { passive: true });
      })();
    </script>
  </body>
</html>

<style>
  :global(*) {
    box-sizing: border-box;
  }

  :global(html) {
    min-height: 100%;
    background: #0f0f0f;
  }

  :global(body) {
    min-height: 100vh;
    margin: 0;
    font-family: "Georgia", "Times New Roman", serif;
    /*
      The visible background comes from .site-parallax. Keeping body transparent
      prevents the fixed decorative layer from being covered by an opaque page
      background while still letting html provide a safe fallback color.
    */
    background: transparent;
    color: #e8e6e3;
    line-height: 1.75;
  }

  :global(a) {
    color: #d4b26a;
    text-decoration: none;
  }

  :global(a:hover) {
    text-decoration: underline;
  }

  .site-header {
    position: relative;
    z-index: 10;
    border-bottom: 1px solid rgba(212, 178, 106, 0.16);
    background: rgba(20, 20, 20, 0.88);
    backdrop-filter: blur(8px);
  }

  .site-header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    max-width: 950px;
    margin: 0 auto;
    padding: 1rem 2rem;
  }

  .site-header h1 {
    margin: 0;
    font-size: 1.5rem;
    line-height: 1.2;
  }

  .site-header h1 a {
    color: #e8e6e3;
    text-decoration: none;
  }

  .site-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .site-nav a {
    font-size: 0.95rem;
    opacity: 0.9;
  }

  .site-nav a:hover {
    opacity: 1;
  }

  main {
    position: relative;
    z-index: 1;
    max-width: 800px;
    margin: 0 auto;
    padding: 2rem;
  }

  h2 {
    margin-top: 0;
    font-size: 1.8rem;
  }

  h3 {
    margin-top: 2rem;
    padding-bottom: 0.3rem;
    border-bottom: 1px solid #2a2a2a;
    font-size: 1.2rem;
  }

  p {
    margin: 0.8rem 0;
  }

  hr {
    margin: 2rem 0;
    border: none;
    border-top: 1px solid #2a2a2a;
  }

  ul {
    padding-left: 1.2rem;
  }

  li {
    margin: 0.4rem 0;
  }

  @media (max-width: 640px) {
    .site-header-inner {
      align-items: flex-start;
      flex-direction: column;
    }

    main {
      padding: 1.25rem;
    }
  }
</style>
