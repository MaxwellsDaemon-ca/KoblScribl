---
interface Props {
  title: string;
  description?: string;
}

const { title,
  description = "Kobold keep many scribls. Some shiny, some messy, some bite back."
 } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width" />
  <meta name="description" content={description} />

  <title>{title} | KoblScribl</title>

  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={Astro.url.href} />
  <meta property="og:site_name" content="KoblScribl" />
  <meta property="og:type" content="website" />
</head>
  <body>
    <header class="site-header">
  <div class="site-header-inner">
    <h1><a href="/">KoblScribl</a></h1>

    <nav class="site-nav" aria-label="Main navigation">
      <a href="/">Home</a>
      <a href="/works">Scribls!</a>
    </nav>
  </div>
</header>

    <main>
      <slot />
    </main>
  </body>
</html>

<style>
  :global(body) {
    margin: 0;
    font-family: "Georgia", "Times New Roman", serif;
    background: #0f0f0f;
    color: #e8e6e3;
    line-height: 1.75;
  }

  :global(a) {
    color: #d4b26a;
    text-decoration: none;
  }

  :global(a:hover) {
    text-decoration: underline;
  }

  .site-header {
    border-bottom: 1px solid #2a2a2a;
    background: #141414;
  }

  .site-header-inner {
    max-width: 950px;
    margin: 0 auto;
    padding: 1rem 2rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
  }

  .site-header h1 {
    margin: 0;
    font-size: 1.5rem;
    line-height: 1.2;
  }

  .site-header h1 a {
    color: #e8e6e3;
    text-decoration: none;
  }

  .site-nav {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .site-nav a {
    font-size: 0.95rem;
    opacity: 0.9;
  }

  .site-nav a:hover {
    opacity: 1;
  }

  main {
    max-width: 800px;
    margin: 0 auto;
    padding: 2rem;
  }

  article {
    margin-top: 1.5rem;
  }

  h2 {
    margin-top: 0;
    font-size: 1.8rem;
  }

  h3 {
    margin-top: 2rem;
    font-size: 1.2rem;
    border-bottom: 1px solid #2a2a2a;
    padding-bottom: 0.3rem;
  }

  p {
    margin: 0.8rem 0;
  }

  hr {
    border: none;
    border-top: 1px solid #2a2a2a;
    margin: 2rem 0;
  }

  ul {
    padding-left: 1.2rem;
  }

  li {
    margin: 0.4rem 0;
  }
</style>