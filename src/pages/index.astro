---
/**
 * Homepage route for KoblScribl.
 *
 * This page introduces the archive, provides high-level context for the author/brand,
 * and gives readers direct entry points into the main works directory sections.
 */
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="KoblScribl">
  <section class="home-page">
    <!-- Primary landing section with the archive name, tagline, and main calls to action. -->
    <header class="hero">
      <p class="eyebrow">Little Hoard of Stories</p>
      <h2>KoblScribl</h2>

      <p class="hero-text">
        Kobold keep many scribls. Some shiny, some messy, some bite back. All kept here,
        safe in hoard.
      </p>

      <div class="hero-actions" aria-label="Primary browsing links">
        <a class="button-primary" href="/works">Dig Through Hoard</a>
        <a class="button-secondary" href="/works/originals">Kobold-Made Tales</a>
      </div>
    </header>

    <!-- Author/archive overview. Kept as static copy so the homepage feels personal and intentional. -->
    <section class="home-section" aria-labelledby="about-kobold-heading">
      <h3 id="about-kobold-heading">About the Kobold</h3>

      <div class="about-card">
        <p>
          I write under the names <strong>IshaTheKobold</strong> and <strong>Maxwell’s Daemon</strong>,
          depending on where you’ve found me. This archive is a place for the stories that
          have collected around me over time: fanworks, original pieces, strange little ideas,
          and the occasional thing that grew claws when I wasn’t looking.
        </p>

        <p>
          Most of what I write leans character-first. I’m drawn to stories shaped by
          relationships, worldbuilding, and the moments where people are forced to confront
          themselves, each other, or the worlds they live in. The tone varies, but you’ll
          find a mix of wonder, emotional weight, moral testing, and the occasional sharp edge.
        </p>

        <p>
          Some works here include mature themes, emotional heaviness, and NSFW content.
          Anything important should be tagged where it matters, though some stories do have
          a habit of wandering into darker corners than expected. Any stories marked as NSFW,
          please ensure you are of legal age in your location before reading.
        </p>

        <p>
          Think of this as a somewhat organized hoard of scribbles. I can’t promise every
          piece will be for you, but I do hope you find something here worth carrying away.
        </p>

        <p class="about-closing">If not, well. The hoard keeps growing anyway.</p>
      </div>
    </section>

    <!-- Static category explainer cards. These summarize the archive taxonomy before linking readers deeper. -->
    <section class="home-section" aria-labelledby="archive-categories-heading">
      <h3 id="archive-categories-heading">What in Hoard?</h3>

      <div class="info-grid">
        <article class="info-card">
          <h4>Fan-Scribls</h4>
          <p>Stories from other worlds. Kobold borrow shiny ideas, make new shinies.</p>
        </article>

        <article class="info-card">
          <h4>Cross-Scribls</h4>
          <p>Two worlds smash together. Sometimes works. Sometimes explodes. Always interesting.</p>
        </article>

        <article class="info-card">
          <h4>True Kobold Tales</h4>
          <p>Original stories. No borrowing. All hoard-made.</p>
        </article>
      </div>
    </section>

    <!-- Secondary navigation cards for users who want to browse by archive section. -->
    <section class="home-section" aria-labelledby="browse-links-heading">
      <h3 id="browse-links-heading">Where Dig?</h3>

      <div class="browse-grid">
        <a class="browse-card" href="/works">
          <span class="browse-title">Whole Hoard</span>
          <span class="browse-text">Everything piled together. Careful where you step.</span>
        </a>

        <a class="browse-card" href="/works/crossovers">
          <span class="browse-title">Cross-Scribls</span>
          <span class="browse-text">Worlds tangled up in strange ways.</span>
        </a>

        <a class="browse-card" href="/works/originals">
          <span class="browse-title">Kobold Originals</span>
          <span class="browse-text">Stories born in this hoard alone.</span>
        </a>
      </div>
    </section>
  </section>
</BaseLayout>

<style>
  /*
    Homepage-specific layout styles.

    Global typography, page width, background, and navigation are handled by BaseLayout.
    These rules only define the homepage sections, cards, and landing-page actions.
  */

  .home-page {
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  /* Hero / landing block */

  .hero {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 1rem 0 0.5rem;
  }

  .eyebrow {
    margin: 0;
    color: #cfc7bb;
    font-size: 0.9rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .hero h2 {
    margin: 0;
    font-size: 2.4rem;
    line-height: 1.1;
  }

  .hero-text {
    max-width: 60ch;
    margin: 0;
    font-size: 1.05rem;
    opacity: 0.95;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 0.5rem;
  }

  /*
    Button styles are intentionally local to the homepage.
    Directory cards elsewhere use shared-directory.css instead.
  */

  .button-primary,
  .button-secondary {
    display: inline-block;
    padding: 0.7rem 1rem;
    border: 1px solid #3a3a3a;
    border-radius: 0.65rem;
    text-decoration: none;
  }

  .button-primary {
    background: #1d1d1d;
  }

  .button-secondary {
    background: #151515;
  }

  .button-primary:hover,
  .button-secondary:hover {
    border-color: #d4b26a;
    background: #1b1b1b;
    transform: translateY(-1px);
    outline: none;
  }

  /* Shared homepage section structure */

  .home-section {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .home-section h3 {
    margin-bottom: 0;
  }

  /*
    Responsive grids automatically collapse to one column when the viewport
    can no longer support 220px cards.
  */

  .info-grid,
  .browse-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1rem;
  }

  /*
    Card base styles shared by informational cards, browse links, and the about block.
    Individual card types add behavior or spacing below.
  */

  .info-card,
  .browse-card,
  .about-card {
    border: 1px solid #2a2a2a;
    border-radius: 0.75rem;
    background: #151515;
    padding: 1rem;
  }

  .about-card {
    padding: 1.25rem;
  }

  .info-card h4 {
    margin: 0 0 0.5rem;
    font-size: 1.1rem;
  }

  .info-card p,
  .about-card p:last-child {
    margin: 0;
  }

  /* Browse cards are full-card links, so their hover state needs to read as interactive. */

  .browse-card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    text-decoration: none;
  }

  .browse-card:hover {
    border-color: #d4b26a;
    background: #1b1b1b;
    transform: translateY(-1px);
    outline: none;
  }

  .browse-title {
    font-size: 1.05rem;
    font-weight: 600;
  }

  .browse-text {
    color: #cfc7bb;
  }

  /* About copy uses standard paragraph spacing inside a carded container. */

  .about-card p {
    margin: 0 0 1rem;
  }

  .about-closing {
    font-style: italic;
    opacity: 0.9;
  }
</style>