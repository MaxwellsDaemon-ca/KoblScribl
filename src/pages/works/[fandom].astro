---
/**
 * Dynamic fandom archive route.
 *
 * This page generates one `/works/[fandom]` route for each fandom represented by
 * published fanfiction entries. It displays that fandom's series and one-shots,
 * with NSFW confirmation support for any linked work marked as mature.
 */
import BaseLayout from "../../layouts/BaseLayout.astro";
import NsfwModal from "../../components/NsfwModal.astro";
import TagList from "../../components/TagList.astro";
import "../../styles/shared-directory.css";
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";
import { buildSeriesCards, sortByTitle } from "../../lib/workUtils";
import { marked } from "marked";

interface Props {
  fandom: string;
  fandomSlug: string;
}

/**
 * Renders short markdown-enabled summaries from frontmatter.
 *
 * Series summaries may include light formatting such as italics, so they are passed
 * through `marked` before being injected into the card body.
 */
const md = (text: string) => marked.parse(text);

export async function getStaticPaths() {
  const works: CollectionEntry<"works">[] = await getCollection("works");
  const fandomMap = new Map<string, string>();

  /**
   * Build one route per fandom slug used by published fanfiction entries.
   *
   * The map prevents duplicate routes when multiple works belong to the same fandom.
   * Slugs are used as route params, while the display fandom name is passed as a prop.
   */
  for (const work of works) {
    if (!work.data.published || work.data.category !== "fanfiction") continue;

    for (let index = 0; index < work.data.fandoms.length; index++) {
      const fandom = work.data.fandoms[index];
      const fandomSlug = work.data.fandomSlug[index];

      if (!fandomMap.has(fandomSlug)) {
        fandomMap.set(fandomSlug, fandom);
      }
    }
  }

  return [...fandomMap.entries()].map(([fandomSlug, fandom]) => ({
    params: { fandom: fandomSlug },
    props: { fandom, fandomSlug },
  }));
}

const { fandom, fandomSlug } = Astro.props as Props;
const works: CollectionEntry<"works">[] = await getCollection("works");

/**
 * Limit this route to published fanfiction entries that belong to the current fandom.
 *
 * Crossover and original works are intentionally excluded because they have their own
 * dedicated archive routes.
 */
const fandomWorks = works.filter(
  (work) =>
    work.data.published &&
    work.data.category === "fanfiction" &&
    work.data.fandoms.includes(fandom)
);

const seriesWorks = fandomWorks.filter((work) => work.data.workType === "series");
const oneShots = fandomWorks.filter((work) => work.data.workType === "oneshot");

/**
 * Shared helpers keep card metadata consistent across fandom, crossover, and original pages.
 */
const sortedSeries = buildSeriesCards(seriesWorks);
const sortedOneShots = [...oneShots].sort(sortByTitle);
---

<BaseLayout title={`${fandom} Scribls`} description={`Hoard of ${fandom} Scribls`}>
  <section class="category-page">
    <p class="breadcrumb">
      <a href="/works">Scribls!</a> / <span>{fandom}</span>
    </p>

    <header class="category-header">
      <h2>{fandom}</h2>
    </header>

    <!-- Series cards group chapter entries by series title and link to the series index route. -->
    <section class="category-section" aria-labelledby="series-heading">
      <h3 id="series-heading">Series</h3>

      {sortedSeries.length === 0 ? (
        <p>No series yet.</p>
      ) : (
        <div class="series-grid">
          {sortedSeries.map((series) => (
            series.seriesSlug ? (
              <article class="series-card full-card-link">
                <!--
                  Stretched link makes the full card clickable while preserving readable card markup.
                  NSFW links are intercepted by NsfwModal unless the reader has already confirmed.
                -->
                <a
                  class:list={["card-stretched-link", { "nsfw-link": series.containsNsfw }]}
                  href={`/works/${fandomSlug}/${series.seriesSlug}`}
                  data-nsfw={series.containsNsfw ? "true" : "false"}
                  aria-label={`Open ${series.seriesTitle}`}
                ></a>

                <div class="card-content">
                  <h4>{series.seriesTitle}</h4>

                  {series.containsNsfw && <p class="nsfw-warning">Contains NSFW content!</p>}

                  <p class="series-counts">
                    {series.totalCount} chapter{series.totalCount === 1 ? "" : "s"}
                  </p>

                  <ul class="series-meta">
                    <li>{series.mainCount} main</li>
                    <li>{series.sideCount} side</li>
                  </ul>

                  {series.summary && <div class="series-summary" set:html={md(series.summary)} />}
                </div>
              </article>
            ) : (
              /*
                Fallback card for malformed or incomplete series metadata.
                The card is still displayed, but it is not linked because no safe URL can be built.
              */
              <article class="series-card">
                <h4>{series.seriesTitle}</h4>

                {series.containsNsfw && <p class="nsfw-warning">Contains NSFW content!</p>}

                <p class="series-counts">
                  {series.totalCount} chapter{series.totalCount === 1 ? "" : "s"}
                </p>

                <ul class="series-meta">
                  <li>{series.mainCount} main</li>
                  <li>{series.sideCount} side</li>
                </ul>

                {series.summary && <div class="series-summary" set:html={md(series.summary)} />}
              </article>
            )
          ))}
        </div>
      )}
    </section>

    <!-- One-shots link directly to their reading pages because they do not have a series index. -->
    <section class="category-section" aria-labelledby="oneshots-heading">
      <h3 id="oneshots-heading">One-Shots</h3>

      {sortedOneShots.length === 0 ? (
        <p>No one-shots yet.</p>
      ) : (
        <div class="oneshot-list">
          {sortedOneShots.map((work) => (
            <article class="oneshot-card full-card-link">
              <a
                class:list={["card-stretched-link", { "nsfw-link": work.data.nsfw }]}
                href={`/works/read/${work.id}`}
                data-nsfw={work.data.nsfw ? "true" : "false"}
                aria-label={`Open ${work.data.title}`}
              ></a>

              <div class="card-content">
                <h4>{work.data.title}</h4>

                {work.data.nsfw && <p class="nsfw-warning">Contains NSFW content!</p>}

                <p class="oneshot-summary">{work.data.summary}</p>
                <p class="oneshot-meta">Word Count: {work.data.wordCount}</p>

                <TagList tags={work.data.tags ?? []} grouped={false} />
              </div>
            </article>
          ))}
        </div>
      )}
    </section>
  </section>

  <!-- Shared confirmation modal used by any link with data-nsfw="true". -->
  <NsfwModal />
</BaseLayout>