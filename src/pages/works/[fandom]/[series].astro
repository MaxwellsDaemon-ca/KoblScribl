---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";
import { marked } from "marked";

const md = (text: string) => marked.parse(text);

interface Props {
  fandom: string;
  fandomSlug: string;
  series: string;
  seriesTitle: string;
}

export async function getStaticPaths() {
  const works: CollectionEntry<"works">[] = await getCollection("works");

  const seen = new Set<string>();
  const paths: {
    fandom: string;
    fandomSlug: string;
    series: string;
    seriesTitle: string;
  }[] = [];

  for (const work of works) {
    if (!work.data.published || work.data.category !== "fanfiction") continue;
    if (work.data.workType !== "series") continue;
    if (!work.data.seriesTitle || !work.data.seriesSlug) continue;

    for (let i = 0; i < work.data.fandoms.length; i++) {
      const fandom = work.data.fandoms[i];
      const fandomSlug = work.data.fandomSlug[i];
      const key = `${fandomSlug}::${work.data.seriesSlug}`;

      if (seen.has(key)) continue;
      seen.add(key);

      paths.push({
        fandom,
        fandomSlug,
        series: work.data.seriesSlug,
        seriesTitle: work.data.seriesTitle,
      });
    }
  }

  return paths.map((entry) => ({
    params: {
      fandom: entry.fandomSlug,
      series: entry.series,
    },
    props: {
      fandom: entry.fandom,
      fandomSlug: entry.fandomSlug,
      series: entry.series,
      seriesTitle: entry.seriesTitle,
    },
  }));
}

const { fandom, fandomSlug, series, seriesTitle } = Astro.props as Props;

const works: CollectionEntry<"works">[] = await getCollection("works");

const seriesWorks = works
  .filter(
    (work) =>
      work.data.published &&
      work.data.category === "fanfiction" &&
      work.data.workType === "series" &&
      work.data.seriesSlug === series &&
      work.data.fandoms.includes(fandom)
  )
  .sort((a, b) => (a.data.chapterNumber ?? 0) - (b.data.chapterNumber ?? 0));

const mainChapters = seriesWorks.filter((work) => work.data.storyGroup === "main");
const sideStories = seriesWorks.filter((work) => work.data.storyGroup === "side");
const seriesSummary = seriesWorks[0]?.data.seriesSummary ?? "";
---

<BaseLayout title={`${seriesTitle} - ${fandom}`}>
  <section class="series-page">
    <p class="breadcrumb">
      <a href="/works">Scribls!</a> /
      <a href={`/works/${fandomSlug}`}>{fandom}</a> /
      <span>{seriesTitle}</span>
    </p>

    <header class="series-header">
      <h2>{seriesTitle}</h2>
      {seriesSummary && (
        <div
          class="series-summary"
          set:html={md(seriesSummary)}
        />
      )}
    </header>

    <section class="series-section">
      <h3>Main Story</h3>

      {mainChapters.length === 0 ? (
        <p>No main chapters yet.</p>
      ) : (
        <div class="chapter-list">
          {mainChapters.map((work) => (
            <article class="chapter-card">
              <h4>
                <a href={`/works/read/${work.id}`}>
                  Chapter {work.data.chapterNumber}: {work.data.chapterTitle ?? work.data.title}
                </a>
              </h4>

              <p class="chapter-summary">{work.data.summary}</p>
              <p class="chapter-meta">Word Count: {work.data.wordCount}</p>
            </article>
          ))}
        </div>
      )}
    </section>

    <section class="series-section">
      <h3>Side Stories</h3>

      {sideStories.length === 0 ? (
        <p>No side stories.</p>
      ) : (
        <div class="chapter-list">
          {sideStories.map((work) => (
            <article class="chapter-card">
              <h4>
                <a href={`/works/read/${work.id}`}>
                  {work.data.title}
                </a>
              </h4>

              <p class="chapter-summary">{work.data.summary}</p>
              <p class="chapter-meta">Word Count: {work.data.wordCount}</p>
              {work.data.contentWarnings && (
                <p class="chapter-warning">CW: {work.data.contentWarnings}</p>
              )}
            </article>
          ))}
        </div>
      )}
    </section>
  </section>
</BaseLayout>

<style>
  .breadcrumb {
    margin: 0 0 1rem 0;
    font-size: 0.95rem;
    opacity: 0.8;
  }

  .breadcrumb a {
    text-decoration: none;
  }

  .series-page {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .series-header h2 {
    margin-bottom: 0.5rem;
  }

  .series-summary p {
    margin: 0 0 0.75rem 0;
  }

  .series-summary p:last-child {
    margin-bottom: 0;
  }

  .series-section {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .series-section h3 {
    margin-bottom: 0;
  }

  .chapter-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .chapter-card {
    border: 1px solid #2a2a2a;
    background: #151515;
    border-radius: 0.75rem;
    padding: 1rem;
  }

  .chapter-card h4 {
    margin: 0 0 0.5rem 0;
    font-size: 1.1rem;
  }

  .chapter-card h4 a {
    text-decoration: none;
  }

  .chapter-summary {
    margin: 0 0 0.75rem 0;
    opacity: 0.95;
  }

  .chapter-meta {
    margin: 0;
    color: #cfc7bb;
  }

  .chapter-warning {
    margin-top: 0.75rem;
    font-style: italic;
  }

  .authors-note img {
    display: inline-block;
    vertical-align: middle;
    margin-left: 0.5rem;
    height: 31px;
    position: relative;
    top: -1px; 
  }
</style>