---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";

interface Props {
  fandom: string;
  series: string;
}

export async function getStaticPaths() {
  const works: CollectionEntry<"works">[] = await getCollection("works");

  const seen = new Set<string>();
  const paths: { fandom: string; series: string }[] = [];

  for (const work of works) {
    if (!work.data.published || work.data.isCrossover) continue;
    if (work.data.workType !== "series") continue;
    if (!work.data.seriesTitle) continue;

    for (const fandom of work.data.fandoms) {
      const key = `${fandom}::${work.data.seriesTitle}`;

      if (seen.has(key)) continue;
      seen.add(key);

      paths.push({
        fandom,
        series: work.data.seriesTitle,
      });
    }
  }

  return paths.map((entry) => ({
    params: {
      fandom: entry.fandom,
      series: entry.series,
    },
    props: {
      fandom: entry.fandom,
      series: entry.series,
    },
  }));
}

const { fandom, series } = Astro.props as Props;

const works: CollectionEntry<"works">[] = await getCollection("works");

const seriesWorks = works
  .filter(
    (work) =>
      work.data.published &&
      !work.data.isCrossover &&
      work.data.workType === "series" &&
      work.data.seriesTitle === series &&
      work.data.fandoms.includes(fandom)
  )
  .sort(
    (a, b) => (a.data.chapterNumber ?? 0) - (b.data.chapterNumber ?? 0)
  );

const mainChapters = seriesWorks.filter((work) => work.data.storyGroup === "main");
const sideStories = seriesWorks.filter((work) => work.data.storyGroup === "side");
---

<BaseLayout title={`${series} - ${fandom}`}>
  <h2>{series}</h2>
  <p>{fandom}</p>

  <h3>Main Story</h3>
  {mainChapters.length === 0 ? (
    <p>No main chapters yet.</p>
  ) : (
    <ul>
      {mainChapters.map((work) => (
        <li>
          <a href={`/works/read/${work.id}`}>
            Chapter {work.data.chapterNumber}: {work.data.chapterTitle ?? work.data.title}
          </a>
        </li>
      ))}
    </ul>
  )}

  <h3>Side Stories</h3>
  {sideStories.length === 0 ? (
    <p>No side stories.</p>
  ) : (
    <ul>
      {sideStories.map((work) => (
        <li>
          <a href={`/works/read/${work.id}`}>
            {work.data.title}
          </a>
        </li>
      ))}
    </ul>
  )}
</BaseLayout>