---
/**
 * Dynamic fanfiction series index route.
 *
 * This page generates `/works/[fandom]/[series]` routes for published fanfiction series.
 * It lists main chapters and side stories separately, displays the series summary, and
 * collects series-wide tags from the chapter metadata.
 */
import BaseLayout from "../../../layouts/BaseLayout.astro";
import TagList from "../../../components/TagList.astro";
import "../../../styles/shared-directory.css";
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";
import { chapterDisplayTitle, collectSeriesTags, sortByChapterNumber } from "../../../lib/workUtils";
import { marked } from "marked";

interface Props {
  fandom: string;
  fandomSlug: string;
  series: string;
  seriesTitle: string;
}

/**
 * Renders markdown-enabled series summaries from frontmatter.
 *
 * This allows light formatting such as italics or inline emphasis without requiring
 * a separate content file for the series description.
 */
const md = (text: string) => marked.parse(text);

export async function getStaticPaths() {
  const works: CollectionEntry<"works">[] = await getCollection("works");
  const seen = new Set<string>();
  const paths: Props[] = [];

  /**
   * Generate each fandom-series route once, even when multiple chapters share it.
   *
   * A single series may have many chapter entries, so the `seen` key prevents duplicate
   * static paths for the same fandom slug and series slug combination.
   */
  for (const work of works) {
    if (!work.data.published || work.data.category !== "fanfiction") continue;
    if (work.data.workType !== "series") continue;
    if (!work.data.seriesTitle || !work.data.seriesSlug) continue;

    for (let index = 0; index < work.data.fandoms.length; index++) {
      const fandom = work.data.fandoms[index];
      const fandomSlug = work.data.fandomSlug[index];
      const key = `${fandomSlug}::${work.data.seriesSlug}`;

      if (seen.has(key)) continue;
      seen.add(key);

      paths.push({
        fandom,
        fandomSlug,
        series: work.data.seriesSlug,
        seriesTitle: work.data.seriesTitle,
      });
    }
  }

  return paths.map((entry) => ({
    params: { fandom: entry.fandomSlug, series: entry.series },
    props: entry,
  }));
}

const { fandom, fandomSlug, series, seriesTitle } = Astro.props as Props;
const works: CollectionEntry<"works">[] = await getCollection("works");

/**
 * Pull the published chapters that belong to this fandom-specific series route.
 *
 * The fandom check matters because the same series slug could theoretically appear
 * under a different fandom or category. The final sort controls reading order.
 */
const seriesWorks = works
  .filter(
    (work) =>
      work.data.published &&
      work.data.category === "fanfiction" &&
      work.data.workType === "series" &&
      work.data.seriesSlug === series &&
      work.data.fandoms.includes(fandom)
  )
  .sort(sortByChapterNumber);

/**
 * Main chapters and side stories are displayed as separate sections.
 *
 * Main chapters use the normalized chapter display helper so chapter zero appears
 * as `Prologue` instead of `Chapter 0`.
 */
const mainChapters = seriesWorks.filter((work) => work.data.storyGroup === "main");
const sideStories = seriesWorks.filter((work) => work.data.storyGroup === "side");

const seriesSummary = seriesWorks[0]?.data.seriesSummary ?? "";

/**
 * Series tags are collected from the series entries and deduplicated by tag type/slug.
 * This keeps the index page representative without repeating tags from every chapter.
 */
const seriesTags = collectSeriesTags(seriesWorks);
---

<BaseLayout title={seriesTitle} description={seriesSummary}>
  <section class="series-page">
    <p class="breadcrumb">
      <a href="/works">Scribls!</a> /
      <a href={`/works/${fandomSlug}`}>{fandom}</a> /
      <span>{seriesTitle}</span>
    </p>

    <header class="series-header">
      <h2>{seriesTitle}</h2>

      {seriesSummary && <div class="series-summary" set:html={md(seriesSummary)} />}

      <TagList tags={seriesTags} grouped={true} />
    </header>

    <!-- Main story chapter list, ordered by chapterNumber. -->
    <section class="series-section" aria-labelledby="main-story-heading">
      <h3 id="main-story-heading">Main Story</h3>

      {mainChapters.length === 0 ? (
        <p>No main chapters yet.</p>
      ) : (
        <div class="chapter-list">
          {mainChapters.map((work) => (
            <article class="chapter-card full-card-link">
              <!--
                Stretched link makes the full chapter card clickable while keeping the
                visible title, summary, and metadata in normal semantic elements.
              -->
              <a
                class="card-stretched-link"
                href={`/works/read/${work.id}`}
                aria-label={`Open ${chapterDisplayTitle(work)}`}
              ></a>

              <div class="card-content">
                <h4>{chapterDisplayTitle(work)}</h4>
                <p class="chapter-summary">{work.data.summary}</p>
                <p class="chapter-meta">Word Count: {work.data.wordCount}</p>
              </div>
            </article>
          ))}
        </div>
      )}
    </section>

    <!-- Side stories are shown separately because they may not belong to the main reading order. -->
    <section class="series-section" aria-labelledby="side-stories-heading">
      <h3 id="side-stories-heading">Side Stories</h3>

      {sideStories.length === 0 ? (
        <p>No side stories.</p>
      ) : (
        <div class="chapter-list">
          {sideStories.map((work) => (
            <article class="chapter-card full-card-link">
              <a
                class="card-stretched-link"
                href={`/works/read/${work.id}`}
                aria-label={`Open ${work.data.title}`}
              ></a>

              <div class="card-content">
                <h4>{work.data.title}</h4>
                <p class="chapter-summary">{work.data.summary}</p>
                <p class="chapter-meta">Word Count: {work.data.wordCount}</p>

                <!-- Side stories can carry their own tags and warnings apart from the main series. -->
                <TagList tags={work.data.tags ?? []} grouped={false} />

                {work.data.contentWarnings && (
                  <p class="chapter-warning">CW: {work.data.contentWarnings}</p>
                )}
              </div>
            </article>
          ))}
        </div>
      )}
    </section>
  </section>
</BaseLayout>