---
/**
 * Crossover works index route.
 *
 * This page lists every published crossover work in the archive and separates them into
 * series and one-shot sections. Crossover-specific fandom pills are shown on each card
 * so readers can quickly see which fandoms are involved before opening the work.
 */
import BaseLayout from "../../layouts/BaseLayout.astro";
import NsfwModal from "../../components/NsfwModal.astro";
import TagList from "../../components/TagList.astro";
import "../../styles/shared-directory.css";
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";
import { buildSeriesCards, sortByTitle } from "../../lib/workUtils";

const works: CollectionEntry<"works">[] = await getCollection("works");

/**
 * Pull only published crossover entries for this archive section.
 *
 * Fanfiction and original works are excluded because they are handled by their own
 * dedicated index routes.
 */
const crossoverWorks = works.filter(
  (work) => work.data.published && work.data.category === "crossover"
);

/**
 * Series entries are grouped into series cards, while one-shots are displayed as
 * individual reading-page cards.
 */
const seriesWorks = crossoverWorks.filter((work) => work.data.workType === "series");
const oneShots = crossoverWorks.filter((work) => work.data.workType === "oneshot");

/**
 * Shared utilities keep sorting and series-card metadata consistent across archive pages.
 */
const sortedSeries = buildSeriesCards(seriesWorks);
const sortedOneShots = [...oneShots].sort(sortByTitle);
---

<BaseLayout title="Crossover Scribls" description="Hoard of smushed-together Scribls">
  <section class="category-page">
    <p class="breadcrumb">
      <a href="/works">Scribls!</a> / <span>Crossovers</span>
    </p>

    <header class="category-header">
      <h2>Crossovers</h2>
    </header>

    <!-- Series cards link to crossover-specific series index pages. -->
    <section class="category-section" aria-labelledby="crossover-series-heading">
      <h3 id="crossover-series-heading">Series</h3>

      {sortedSeries.length === 0 ? (
        <p>No crossover series yet.</p>
      ) : (
        <div class="series-grid">
          {sortedSeries.map((series) => (
            series.seriesSlug ? (
              <article class="series-card full-card-link">
                <!--
                  Full-card link target for the series page.
                  Links marked with data-nsfw="true" are intercepted by the shared NSFW modal.
                -->
                <a
                  class:list={["card-stretched-link", { "nsfw-link": series.containsNsfw }]}
                  href={`/works/crossovers/${series.seriesSlug}`}
                  data-nsfw={series.containsNsfw ? "true" : "false"}
                  aria-label={`Open ${series.seriesTitle}`}
                ></a>

                <div class="card-content">
                  <h4>{series.seriesTitle}</h4>

                  <!-- Fandom pills show every fandom represented in the crossover series. -->
                  <div class="pill-list">
                    {series.fandoms.map((fandom) => (
                      <span class="fandom-pill">{fandom.toUpperCase()}</span>
                    ))}
                    <span class="fandom-pill crossover-pill">CROSSOVER</span>
                  </div>

                  {series.containsNsfw && <p class="nsfw-warning">Contains NSFW content!</p>}

                  <p class="series-counts">
                    {series.totalCount} chapter{series.totalCount === 1 ? "" : "s"}
                  </p>

                  <ul class="series-meta">
                    <li>{series.mainCount} main</li>
                    <li>{series.sideCount} side</li>
                  </ul>

                  {series.summary && <p class="series-summary">{series.summary}</p>}
                </div>
              </article>
            ) : (
              /*
                Fallback card for series entries missing a usable seriesSlug.
                The content remains visible, but the card is not linked because no safe route exists.
              */
              <article class="series-card">
                <h4>{series.seriesTitle}</h4>

                <div class="pill-list">
                  {series.fandoms.map((fandom) => (
                    <span class="fandom-pill">{fandom.toUpperCase()}</span>
                  ))}
                  <span class="fandom-pill crossover-pill">CROSSOVER</span>
                </div>

                {series.containsNsfw && <p class="nsfw-warning">Contains NSFW content!</p>}

                <p class="series-counts">
                  {series.totalCount} chapter{series.totalCount === 1 ? "" : "s"}
                </p>

                <ul class="series-meta">
                  <li>{series.mainCount} main</li>
                  <li>{series.sideCount} side</li>
                </ul>

                {series.summary && <p class="series-summary">{series.summary}</p>}
              </article>
            )
          ))}
        </div>
      )}
    </section>

    <!-- One-shots link directly to their read pages because they do not have index pages. -->
    <section class="category-section" aria-labelledby="crossover-oneshots-heading">
      <h3 id="crossover-oneshots-heading">One-Shots</h3>

      {sortedOneShots.length === 0 ? (
        <p>No crossover one-shots yet.</p>
      ) : (
        <div class="oneshot-list">
          {sortedOneShots.map((work) => (
            <article class="oneshot-card full-card-link">
              <!--
                One-shot cards use the same stretched-link pattern as series cards.
                This keeps the entire card clickable without wrapping all visible content in the anchor.
              -->
              <a
                class:list={["card-stretched-link", { "nsfw-link": work.data.nsfw }]}
                href={`/works/read/${work.id}`}
                data-nsfw={work.data.nsfw ? "true" : "false"}
                aria-label={`Open ${work.data.title}`}
              ></a>

              <div class="card-content">
                <h4>{work.data.title}</h4>

                <div class="pill-list">
                  {work.data.fandoms.map((fandom: string) => (
                    <span class="fandom-pill">{fandom.toUpperCase()}</span>
                  ))}
                  <span class="fandom-pill crossover-pill">CROSSOVER</span>
                </div>

                {work.data.nsfw && <p class="nsfw-warning">Contains NSFW content!</p>}

                <p class="oneshot-summary">{work.data.summary}</p>
                <p class="oneshot-meta">Word Count: {work.data.wordCount}</p>

                <TagList tags={work.data.tags ?? []} grouped={false} />
              </div>
            </article>
          ))}
        </div>
      )}
    </section>
  </section>

  <!-- Shared confirmation modal used by all links marked with data-nsfw="true". -->
  <NsfwModal />
</BaseLayout>