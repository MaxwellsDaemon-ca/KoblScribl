---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";

const works: CollectionEntry<"works">[] = await getCollection("works");

const crossoverWorks = works.filter(
  (work) => work.data.published && work.data.category === "crossover"
);

const seriesWorks = crossoverWorks.filter((work) => work.data.workType === "series");
const oneShots = crossoverWorks.filter((work) => work.data.workType === "oneshot");

const seriesMap = new Map<string, CollectionEntry<"works">[]>();

for (const work of seriesWorks) {
  const seriesTitle = work.data.seriesTitle ?? "Untitled Series";

  if (!seriesMap.has(seriesTitle)) {
    seriesMap.set(seriesTitle, []);
  }

  seriesMap.get(seriesTitle)!.push(work);
}

for (const [, entries] of seriesMap) {
  entries.sort(
    (a, b) => (a.data.chapterNumber ?? 0) - (b.data.chapterNumber ?? 0)
  );
}

const sortedSeries = [...seriesMap.entries()]
  .map(([seriesTitle, entries]) => {
    const mainCount = entries.filter((entry) => entry.data.storyGroup === "main").length;
    const sideCount = entries.filter((entry) => entry.data.storyGroup === "side").length;

    return {
      seriesTitle,
      entries,
      totalCount: entries.length,
      mainCount,
      sideCount,
      summary: entries[0]?.data.seriesSummary ?? "",
      fandoms: [...new Set(entries.flatMap((entry) => entry.data.fandoms))],
    };
  })
  .sort((a, b) => a.seriesTitle.localeCompare(b.seriesTitle));

const sortedOneShots = [...oneShots].sort((a, b) =>
  a.data.title.localeCompare(b.data.title)
);
---

<BaseLayout title="Crossover Works">
  <section class="category-page">
    <p class="breadcrumb">
      <a href="/works">Scribls!</a> / <span>Crossovers</span>
    </p>

    <header class="category-header">
      <h2>Crossovers</h2>
    </header>

    <section class="category-section">
      <h3>Series</h3>

      {sortedSeries.length === 0 ? (
        <p>No crossover series yet.</p>
      ) : (
        <div class="series-grid">
          {sortedSeries.map((series) => (
            <article class="series-card">
              <h4>
  <a href={`/works/crossovers/${encodeURIComponent(series.seriesTitle)}`}>
    {series.seriesTitle}
  </a>
</h4>

              <div class="pill-list">
                {series.fandoms.map((fandom) => (
                  <span class="fandom-pill">{fandom.toUpperCase()}</span>
                ))}
                <span class="fandom-pill crossover-pill">CROSSOVER</span>
              </div>

              <p class="series-counts">
                {series.totalCount} chapter{series.totalCount === 1 ? "" : "s"}
              </p>

              <ul class="series-meta">
                <li>{series.mainCount} main</li>
                <li>{series.sideCount} side</li>
              </ul>

              {series.summary && <p class="series-summary">{series.summary}</p>}
            </article>
          ))}
        </div>
      )}
    </section>

    <section class="category-section">
      <h3>One-Shots</h3>

      {sortedOneShots.length === 0 ? (
        <p>No crossover one-shots yet.</p>
      ) : (
        <div class="oneshot-list">
          {sortedOneShots.map((work) => (
            <article class="oneshot-card">
              <h4>
                <a href={`/works/read/${work.id}`}>{work.data.title}</a>
              </h4>

              <div class="pill-list">
                {work.data.fandoms.map((fandom) => (
                  <span class="fandom-pill">{fandom.toUpperCase()}</span>
                ))}
                <span class="fandom-pill crossover-pill">CROSSOVER</span>
              </div>

              <p class="oneshot-summary">{work.data.summary}</p>
              <p class="oneshot-meta">Word Count: {work.data.wordCount}</p>
            </article>
          ))}
        </div>
      )}
    </section>
  </section>
</BaseLayout>

<style>
  .breadcrumb {
    margin: 0 0 1rem 0;
    font-size: 0.95rem;
    opacity: 0.8;
  }

  .breadcrumb a {
    text-decoration: none;
  }

  .category-page {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .category-header h2 {
    margin-bottom: 0.5rem;
  }

  .category-intro {
    margin: 0;
    max-width: 60ch;
    opacity: 0.9;
  }

  .category-section {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .category-section h3 {
    margin-bottom: 0;
  }

  .series-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1rem;
  }

  .series-card,
  .oneshot-card {
    border: 1px solid #2a2a2a;
    background: #151515;
    border-radius: 0.75rem;
    padding: 1rem;
  }

  .series-card h4,
  .oneshot-card h4 {
    margin: 0 0 0.5rem 0;
    font-size: 1.1rem;
  }

  .oneshot-card h4 a {
    text-decoration: none;
  }

  .series-counts,
  .oneshot-meta {
    margin: 0 0 0.75rem 0;
    color: #cfc7bb;
  }

  .series-meta {
    margin: 0 0 0.75rem 0;
    padding-left: 1.2rem;
  }

  .series-meta li {
    margin: 0.25rem 0;
  }

  .series-summary,
  .oneshot-summary {
    margin: 0;
    opacity: 0.95;
  }

  .oneshot-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .pill-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin: 0.25rem 0 0.75rem 0;
  }

  .fandom-pill {
    display: inline-block;
    padding: 0.25rem 0.7rem;
    border: 1px solid #5a4a2a;
    border-radius: 999px;
    background: #1a1a1a;
    color: #d4b26a;
    font-size: 0.9rem;
    letter-spacing: 0.04em;
  }

  .crossover-pill {
    border-color: #4f3d5e;
    color: #c9a7e8;
  }
</style>