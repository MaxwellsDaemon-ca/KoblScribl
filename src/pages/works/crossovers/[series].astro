---
/**
 * Dynamic crossover series index route.
 *
 * This page generates `/works/crossovers/[series]` routes for published crossover series.
 * It displays the series summary, fandom pills, series-wide tags, and separate lists for
 * main chapters and side stories.
 */
import BaseLayout from "../../../layouts/BaseLayout.astro";
import TagList from "../../../components/TagList.astro";
import "../../../styles/shared-directory.css";
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";
import { chapterDisplayTitle, collectSeriesTags, sortByChapterNumber } from "../../../lib/workUtils";

interface Props {
  series: string;
  seriesTitle: string;
}

export async function getStaticPaths() {
  const works: CollectionEntry<"works">[] = await getCollection("works");
  const seen = new Set<string>();
  const paths: Props[] = [];

  /**
   * Generate one route per crossover series slug.
   *
   * Each chapter in a series shares the same seriesSlug, so `seen` prevents Astro from
   * receiving duplicate static paths for the same crossover series page.
   */
  for (const work of works) {
    if (!work.data.published || work.data.category !== "crossover") continue;
    if (work.data.workType !== "series") continue;
    if (!work.data.seriesTitle || !work.data.seriesSlug) continue;
    if (seen.has(work.data.seriesSlug)) continue;

    seen.add(work.data.seriesSlug);

    paths.push({
      series: work.data.seriesSlug,
      seriesTitle: work.data.seriesTitle,
    });
  }

  return paths.map((entry) => ({
    params: { series: entry.series },
    props: entry,
  }));
}

const { series, seriesTitle } = Astro.props as Props;
const works: CollectionEntry<"works">[] = await getCollection("works");

/**
 * Pull all published chapters belonging to the current crossover series.
 *
 * Crossover routes are not scoped to a single fandom, so the series slug is enough to
 * identify the chapter group within the crossover category.
 */
const seriesWorks = works
  .filter(
    (work) =>
      work.data.published &&
      work.data.category === "crossover" &&
      work.data.workType === "series" &&
      work.data.seriesSlug === series
  )
  .sort(sortByChapterNumber);

/**
 * Main chapters and side stories are displayed separately.
 *
 * Main chapters follow the primary reading order. Side stories remain visible on the
 * index page, but they do not need to be mixed into the main chapter list.
 */
const mainChapters = seriesWorks.filter((work) => work.data.storyGroup === "main");
const sideStories = seriesWorks.filter((work) => work.data.storyGroup === "side");

/**
 * Build the fandom-pill list for this crossover.
 *
 * The names and slugs are deduplicated independently from the chapter metadata. This
 * assumes each fandom's index in `fandoms` matches its corresponding index in `fandomSlug`
 * across the source frontmatter.
 */
const allFandoms = [...new Set(seriesWorks.flatMap((work) => work.data.fandoms))];
const allFandomSlugs = [...new Set(seriesWorks.flatMap((work) => work.data.fandomSlug))];

const seriesSummary = seriesWorks[0]?.data.seriesSummary ?? "";

/**
 * Series tags are collected from all series entries and deduplicated by tag type/slug.
 * This allows the series index to show broad metadata without repeating the same tag
 * once per chapter.
 */
const seriesTags = collectSeriesTags(seriesWorks);
---

<BaseLayout title={seriesTitle} description={seriesSummary}>
  <section class="series-page">
    <p class="breadcrumb">
      <a href="/works">Scribls!</a> /
      <a href="/works/crossovers">Crossovers</a> /
      <span>{seriesTitle}</span>
    </p>

    <header class="series-header">
      <h2>{seriesTitle}</h2>

      <!-- Fandom pills provide quick context for which worlds are involved in the crossover. -->
      <div class="pill-list">
        {allFandoms.map((fandom, index) => (
          <a class="fandom-pill" href={`/works/${allFandomSlugs[index]}`}>
            {fandom.toUpperCase()}
          </a>
        ))}

        <span class="fandom-pill crossover-pill">CROSSOVER</span>
      </div>

      {seriesSummary && <p class="series-summary">{seriesSummary}</p>}

      <TagList tags={seriesTags} grouped={true} />
    </header>

    <!-- Main story chapter list, ordered by chapterNumber. -->
    <section class="series-section" aria-labelledby="main-story-heading">
      <h3 id="main-story-heading">Main Story</h3>

      {mainChapters.length === 0 ? (
        <p>No main chapters yet.</p>
      ) : (
        <div class="chapter-list">
          {mainChapters.map((work) => (
            <article class="chapter-card full-card-link">
              <!--
                Stretched link makes the whole card clickable while preserving semantic
                card content for titles, summaries, and metadata.
              -->
              <a
                class="card-stretched-link"
                href={`/works/read/${work.id}`}
                aria-label={`Open ${chapterDisplayTitle(work)}`}
              ></a>

              <div class="card-content">
                <h4>{chapterDisplayTitle(work)}</h4>
                <p class="chapter-summary">{work.data.summary}</p>
                <p class="chapter-meta">Word Count: {work.data.wordCount}</p>
              </div>
            </article>
          ))}
        </div>
      )}
    </section>

    <!-- Side stories are listed separately so optional content does not interrupt the main reading order. -->
    <section class="series-section" aria-labelledby="side-stories-heading">
      <h3 id="side-stories-heading">Side Stories</h3>

      {sideStories.length === 0 ? (
        <p>No side stories.</p>
      ) : (
        <div class="chapter-list">
          {sideStories.map((work) => (
            <article class="chapter-card full-card-link">
              <a
                class="card-stretched-link"
                href={`/works/read/${work.id}`}
                aria-label={`Open ${work.data.title}`}
              ></a>

              <div class="card-content">
                <h4>{work.data.title}</h4>
                <p class="chapter-summary">{work.data.summary}</p>
                <p class="chapter-meta">Word Count: {work.data.wordCount}</p>

                <!-- Side stories can carry their own more specific tags. -->
                <TagList tags={work.data.tags ?? []} grouped={false} />
              </div>
            </article>
          ))}
        </div>
      )}
    </section>
  </section>
</BaseLayout>