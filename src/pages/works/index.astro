---
/**
 * Top-level works directory route.
 *
 * This page is the main entry point for the story archive. It groups published works
 * into the three major browsing categories: fandom fanfiction, crossovers, and original works.
 */
import BaseLayout from "../../layouts/BaseLayout.astro";
import "../../styles/shared-directory.css";
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";
import { buildFandomStats } from "../../lib/workUtils";

const works: CollectionEntry<"works">[] = await getCollection("works");

/**
 * Only published works should appear in public archive navigation.
 *
 * Drafts and unpublished entries may still exist in the content collection, but they are
 * intentionally excluded from all counts and links shown on this page.
 */
const publishedWorks = works.filter((work) => work.data.published);

/**
 * Split the archive into its top-level browsing buckets.
 *
 * Fanfiction is further grouped by fandom below, while crossovers and original works
 * each receive a single category card that links to their dedicated index pages.
 */
const originalWorks = publishedWorks.filter((work) => work.data.category === "original");
const crossoverWorks = publishedWorks.filter((work) => work.data.category === "crossover");
const normalWorks = publishedWorks.filter((work) => work.data.category === "fanfiction");

/**
 * Build per-fandom summary cards from published fanfiction works.
 *
 * Entries without fandom metadata are ignored here because the fandom grid depends on
 * matching `fandoms` and `fandomSlug` values to generate valid links.
 */
const fandomStats = buildFandomStats(normalWorks.filter((work) => work.data.fandoms.length > 0));

/**
 * Crossover summary counts.
 *
 * Series are counted by unique title rather than raw chapter count so the card can show
 * how many series are available alongside the total number of crossover works.
 */
const crossoverSeriesTitles = new Set(
  crossoverWorks
    .filter((work) => work.data.workType === "series" && work.data.seriesTitle)
    .map((work) => work.data.seriesTitle!)
);

const crossoverOneShots = crossoverWorks.filter((work) => work.data.workType === "oneshot");

/**
 * Original-work summary counts.
 *
 * Like crossovers, original series are counted by unique series title while one-shots
 * are counted as individual works.
 */
const originalSeriesTitles = new Set(
  originalWorks
    .filter((work) => work.data.workType === "series" && work.data.seriesTitle)
    .map((work) => work.data.seriesTitle!)
);

const originalOneShots = originalWorks.filter((work) => work.data.workType === "oneshot");
---

<BaseLayout title="Scribls!" description="Hoard of Scribls, organized by fandom and category">
  <section class="works-directory">
    <header class="directory-header">
      <h2>Scribls!</h2>
    </header>

    <!-- Fanfiction is displayed as a grid of fandom cards, with one card per fandom slug. -->
    <section class="directory-section" aria-labelledby="fandoms-heading">
      <h3 id="fandoms-heading">Fandoms</h3>

      {fandomStats.length === 0 ? (
        <p>No fandom works have been added yet.</p>
      ) : (
        <div class="category-grid">
          {fandomStats.map((entry) => (
            <a class="category-card" href={`/works/${entry.fandomSlug}`}>
              <h4>{entry.fandom}</h4>

              <p class="category-counts">
                {entry.totalWorks} work{entry.totalWorks === 1 ? "" : "s"}
              </p>

              <ul class="category-meta">
                <li>{entry.seriesCount} series</li>
                <li>{entry.oneShotCount} one-shot{entry.oneShotCount === 1 ? "" : "s"}</li>
              </ul>
            </a>
          ))}
        </div>
      )}
    </section>

    <!-- Crossovers are summarized as a single category card because they have a shared index route. -->
    <section class="directory-section" aria-labelledby="crossovers-heading">
      <h3 id="crossovers-heading">Crossovers</h3>

      {crossoverWorks.length === 0 ? (
        <p>No crossover works have been added yet.</p>
      ) : (
        <div class="single-card-row">
          <a class="category-card" href="/works/crossovers">
            <h4>Browse Crossovers</h4>

            <p class="category-counts">
              {crossoverWorks.length} work{crossoverWorks.length === 1 ? "" : "s"}
            </p>

            <ul class="category-meta">
              <li>{crossoverSeriesTitles.size} series</li>
              <li>
                {crossoverOneShots.length} one-shot{crossoverOneShots.length === 1 ? "" : "s"}
              </li>
            </ul>
          </a>
        </div>
      )}
    </section>

    <!-- Original works are summarized as a single category card with their own index route. -->
    <section class="directory-section" aria-labelledby="original-works-heading">
      <h3 id="original-works-heading">Original Works</h3>

      {originalWorks.length === 0 ? (
        <p>No original works have been added yet.</p>
      ) : (
        <div class="single-card-row">
          <a class="category-card" href="/works/originals">
            <h4>Browse Original Works</h4>

            <p class="category-counts">
              {originalWorks.length} work{originalWorks.length === 1 ? "" : "s"}
            </p>

            <ul class="category-meta">
              <li>{originalSeriesTitles.size} series</li>
              <li>{originalOneShots.length} one-shot{originalOneShots.length === 1 ? "" : "s"}</li>
            </ul>
          </a>
        </div>
      )}
    </section>
  </section>
</BaseLayout>