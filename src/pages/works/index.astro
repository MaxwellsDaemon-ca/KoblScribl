---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";

const works: CollectionEntry<"works">[] = await getCollection("works");

const publishedWorks = works.filter((work) => work.data.published);

const originalWorks = publishedWorks.filter(
  (work) => work.data.category === "original" && work.data.fandoms.length === 0
);

const crossoverWorks = publishedWorks.filter(
  (work) => work.data.category === "crossover" && work.data.fandoms.length > 1
);

const normalWorks = publishedWorks.filter(
  (work) => work.data.category === "fanfiction" && work.data.fandoms.length > 0
);

type FandomStats = {
  fandom: string;
  works: CollectionEntry<"works">[];
  totalWorks: number;
  seriesCount: number;
  oneShotCount: number;
};

const fandomMap = new Map<string, CollectionEntry<"works">[]>();

for (const work of normalWorks) {
  for (const fandom of work.data.fandoms) {
    if (!fandomMap.has(fandom)) {
      fandomMap.set(fandom, []);
    }
    fandomMap.get(fandom)!.push(work);
  }
}

const fandomStats: FandomStats[] = [...fandomMap.entries()]
  .map(([fandom, fandomWorks]) => {
    const seriesTitles = new Set(
      fandomWorks
        .filter((work) => work.data.workType === "series" && work.data.seriesTitle)
        .map((work) => work.data.seriesTitle!)
    );

    const oneShots = fandomWorks.filter((work) => work.data.workType === "oneshot");

    return {
      fandom,
      works: fandomWorks,
      totalWorks: fandomWorks.length,
      seriesCount: seriesTitles.size,
      oneShotCount: oneShots.length,
    };
  })
  .sort((a, b) => a.fandom.localeCompare(b.fandom));

const crossoverSeriesTitles = new Set(
  crossoverWorks
    .filter((work) => work.data.workType === "series" && work.data.seriesTitle)
    .map((work) => work.data.seriesTitle!)
);

const crossoverOneShots = crossoverWorks.filter(
  (work) => work.data.workType === "oneshot"
);

const originalSeriesTitles = new Set(
  originalWorks
    .filter((work) => work.data.workType === "series" && work.data.seriesTitle)
    .map((work) => work.data.seriesTitle!)
);

const originalOneShots = originalWorks.filter(
  (work) => work.data.workType === "oneshot"
);

function slugify(str: string) {
  return str
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/(^-|-$)/g, "");
}
---

<BaseLayout title="Works">
  <section class="works-directory">
    <header class="directory-header">
      <h2>Scribls!</h2>
    </header>

    <section class="directory-section">
      <h3>Fandoms</h3>

      {fandomStats.length === 0 ? (
        <p>No fandom works have been added yet.</p>
      ) : (
        <div class="category-grid">
          {fandomStats.map((entry) => (
            <article class="category-card">
              <h4>
                <a href={`/works/${slugify(entry.fandom)}`}>
                  {entry.fandom}
                </a>
              </h4>

              <p class="category-counts">
                {entry.totalWorks} work{entry.totalWorks === 1 ? "" : "s"}
              </p>

              <ul class="category-meta">
                <li>{entry.seriesCount} series</li>
                <li>{entry.oneShotCount} one-shot{entry.oneShotCount === 1 ? "" : "s"}</li>
              </ul>
            </article>
          ))}
        </div>
      )}
    </section>

    <section class="directory-section">
      <h3>Crossovers</h3>

      {crossoverWorks.length === 0 ? (
        <p>No crossover works have been added yet.</p>
      ) : (
        <div class="single-card-row">
          <article class="category-card">
            <h4>
              <a href="/works/crossovers">Browse Crossovers</a>
            </h4>

            <p class="category-counts">
              {crossoverWorks.length} work{crossoverWorks.length === 1 ? "" : "s"}
            </p>

            <ul class="category-meta">
              <li>{crossoverSeriesTitles.size} series</li>
              <li>{crossoverOneShots.length} one-shot{crossoverOneShots.length === 1 ? "" : "s"}</li>
            </ul>
          </article>
        </div>
      )}
    </section>

    <section class="directory-section">
      <h3>Original Works</h3>

      {originalWorks.length === 0 ? (
        <p>No original works have been added yet.</p>
      ) : (
        <div class="single-card-row">
          <article class="category-card">
            <h4>
              <a href="/works/originals">Browse Original Works</a>
            </h4>

            <p class="category-counts">
              {originalWorks.length} work{originalWorks.length === 1 ? "" : "s"}
            </p>

            <ul class="category-meta">
              <li>{originalSeriesTitles.size} series</li>
              <li>{originalOneShots.length} one-shot{originalOneShots.length === 1 ? "" : "s"}</li>
            </ul>
          </article>
        </div>
      )}
    </section>
  </section>
</BaseLayout>

<style>
  .works-directory {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .directory-header h2 {
    margin-bottom: 0.5rem;
  }

  .directory-intro {
    margin: 0;
    max-width: 60ch;
    opacity: 0.9;
  }

  .directory-section {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .directory-section h3 {
    margin-bottom: 0;
  }

  .category-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1rem;
  }

  .single-card-row {
    max-width: 320px;
  }

  .category-card {
    border: 1px solid #2a2a2a;
    background: #151515;
    border-radius: 0.75rem;
    padding: 1rem;
    height: 100%;
  }

  .category-card h4 {
    margin: 0 0 0.5rem 0;
    font-size: 1.1rem;
  }

  .category-card h4 a {
    text-decoration: none;
  }

  .category-counts {
    margin: 0 0 0.75rem 0;
    color: #cfc7bb;
  }

  .category-meta {
    margin: 0;
    padding-left: 1.2rem;
  }

  .category-meta li {
    margin: 0.25rem 0;
  }
</style>
</style>