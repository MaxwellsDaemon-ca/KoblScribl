---
/**
 * Original works index route.
 *
 * This page lists every published original work in the archive and separates them into
 * series and one-shot sections. Unlike fandom and crossover routes, original works do
 * not require fandom filtering or fandom-pill display.
 */
import BaseLayout from "../../layouts/BaseLayout.astro";
import NsfwModal from "../../components/NsfwModal.astro";
import TagList from "../../components/TagList.astro";
import "../../styles/shared-directory.css";
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";
import { buildSeriesCards, sortByTitle } from "../../lib/workUtils";

const works: CollectionEntry<"works">[] = await getCollection("works");

/**
 * Pull only published original works for this archive section.
 *
 * Fanfiction and crossover works are handled by their own routes, so this page can
 * treat all remaining entries as fandom-independent archive content.
 */
const originalWorks = works.filter(
  (work) => work.data.published && work.data.category === "original"
);

/**
 * Series entries are grouped into index cards, while one-shots link directly to
 * their reading pages.
 */
const seriesWorks = originalWorks.filter((work) => work.data.workType === "series");
const oneShots = originalWorks.filter((work) => work.data.workType === "oneshot");

/**
 * Shared helpers keep original-work sorting and series summary data consistent with
 * the fandom and crossover category pages.
 */
const sortedSeries = buildSeriesCards(seriesWorks);
const sortedOneShots = [...oneShots].sort(sortByTitle);
---

<BaseLayout title="Original Scribls" description="Hoard of original Scribls">
  <section class="category-page">
    <p class="breadcrumb">
      <a href="/works">Scribls!</a> / <span>Original Works</span>
    </p>

    <header class="category-header">
      <h2>Original Works</h2>
    </header>

    <!-- Series cards link to original-work series index pages. -->
    <section class="category-section" aria-labelledby="original-series-heading">
      <h3 id="original-series-heading">Series</h3>

      {sortedSeries.length === 0 ? (
        <p>No original series yet.</p>
      ) : (
        <div class="series-grid">
          {sortedSeries.map((series) => (
            series.seriesSlug ? (
              <article class="series-card full-card-link">
                <!--
                  The stretched link makes the full card clickable while keeping the visible
                  content in normal semantic elements. NSFW-marked links are intercepted by
                  the shared confirmation modal.
                -->
                <a
                  class:list={["card-stretched-link", { "nsfw-link": series.containsNsfw }]}
                  href={`/works/originals/${series.seriesSlug}`}
                  data-nsfw={series.containsNsfw ? "true" : "false"}
                  aria-label={`Open ${series.seriesTitle}`}
                ></a>

                <div class="card-content">
                  <h4>{series.seriesTitle}</h4>

                  {series.containsNsfw && <p class="nsfw-warning">Contains NSFW content!</p>}

                  <p class="series-counts">
                    {series.totalCount} chapter{series.totalCount === 1 ? "" : "s"}
                  </p>

                  <ul class="series-meta">
                    <li>{series.mainCount} main</li>
                    <li>{series.sideCount} side</li>
                  </ul>

                  {series.summary && <p class="series-summary">{series.summary}</p>}
                </div>
              </article>
            ) : (
              /*
                Fallback card for incomplete series metadata.
                If no seriesSlug is available, the series remains visible but is not linked.
              */
              <article class="series-card">
                <h4>{series.seriesTitle}</h4>

                {series.containsNsfw && <p class="nsfw-warning">Contains NSFW content!</p>}

                <p class="series-counts">
                  {series.totalCount} chapter{series.totalCount === 1 ? "" : "s"}
                </p>

                <ul class="series-meta">
                  <li>{series.mainCount} main</li>
                  <li>{series.sideCount} side</li>
                </ul>

                {series.summary && <p class="series-summary">{series.summary}</p>}
              </article>
            )
          ))}
        </div>
      )}
    </section>

    <!-- One-shots link directly to their read pages because they do not have index pages. -->
    <section class="category-section" aria-labelledby="original-oneshots-heading">
      <h3 id="original-oneshots-heading">One-Shots</h3>

      {sortedOneShots.length === 0 ? (
        <p>No original one-shots yet.</p>
      ) : (
        <div class="oneshot-list">
          {sortedOneShots.map((work) => (
            <article class="oneshot-card full-card-link">
              <!--
                Original one-shots use the same full-card link and NSFW warning pattern as
                other archive sections.
              -->
              <a
                class:list={["card-stretched-link", { "nsfw-link": work.data.nsfw }]}
                href={`/works/read/${work.id}`}
                data-nsfw={work.data.nsfw ? "true" : "false"}
                aria-label={`Open ${work.data.title}`}
              ></a>

              <div class="card-content">
                <h4>{work.data.title}</h4>

                {work.data.nsfw && <p class="nsfw-warning">Contains NSFW content!</p>}

                <p class="oneshot-summary">{work.data.summary}</p>
                <p class="oneshot-meta">Word Count: {work.data.wordCount}</p>

                <TagList tags={work.data.tags ?? []} grouped={false} />
              </div>
            </article>
          ))}
        </div>
      )}
    </section>
  </section>

  <!-- Shared confirmation modal used by links marked with data-nsfw="true". -->
  <NsfwModal />
</BaseLayout>