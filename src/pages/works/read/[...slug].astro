---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { getCollection, render } from "astro:content";
import type { CollectionEntry } from "astro:content";
import '../../../styles/texting-style.css';
import '../../../styles/parsel-style.css';

interface Props {
  work: CollectionEntry<"works">;
}

export async function getStaticPaths() {
  const works: CollectionEntry<"works">[] = await getCollection("works");

  return works
    .filter((work) => work.data.published)
    .map((work) => ({
      params: { slug: work.id },
      props: { work },
    }));
}

const { work } = Astro.props as Props;
const { Content } = await render(work);

const baseSummary = work.data.summary;

const description = work.data.contentWarnings
  ? `${baseSummary}\nCW: ${work.data.contentWarnings}`
  : baseSummary;

const allWorks: CollectionEntry<"works">[] = await getCollection("works");

/**
 * Builds the ordered list of main-story chapters for the current series.
 * One-shots and side stories are excluded from prev/next navigation.
 */
const seriesChapters =
  work.data.workType === "series" && work.data.seriesTitle
    ? allWorks
        .filter(
          (entry) =>
            entry.data.published &&
            entry.data.workType === "series" &&
            entry.data.seriesTitle === work.data.seriesTitle &&
            entry.data.storyGroup === "main" &&
            entry.data.fandoms.some((fandom) => work.data.fandoms.includes(fandom))
        )
        .sort(
          (a, b) => (a.data.chapterNumber ?? 0) - (b.data.chapterNumber ?? 0)
        )
    : [];

/**
 * Finds the current chapter index within the ordered main-story chapter list.
 */
const currentChapterIndex = seriesChapters.findIndex(
  (entry) => entry.id === work.id
);

const previousChapter =
  currentChapterIndex > 0 ? seriesChapters[currentChapterIndex - 1] : null;

const nextChapter =
  currentChapterIndex >= 0 &&
  currentChapterIndex < seriesChapters.length - 1
    ? seriesChapters[currentChapterIndex + 1]
    : null;
---

<BaseLayout
  title={work.data.chapterTitle ?? work.data.title}
  description={description}>

  <p class="breadcrumb">
    <a href="/works">Scribls!</a>

    {work.data.category === "fanfiction" && work.data.fandoms[0] && (
      <>
        {" / "}
        <a href={`/works/${work.data.fandomSlug[0]}`}>
          {work.data.fandoms[0]}
        </a>

        {work.data.seriesTitle && work.data.seriesSlug && (
          <>
            {" / "}
            <a href={`/works/${work.data.fandomSlug[0]}/${work.data.seriesSlug}`}>
              {work.data.seriesTitle}
            </a>
          </>
        )}
      </>
    )}

    {work.data.category === "crossover" && (
      <>
        {" / "}
        <a href="/works/crossovers">Crossovers</a>

        {work.data.seriesTitle && work.data.seriesSlug && (
          <>
            {" / "}
            <a href={`/works/crossovers/${work.data.seriesSlug}`}>
              {work.data.seriesTitle}
            </a>
          </>
        )}
      </>
    )}

    {work.data.category === "original" && (
      <>
        {" / "}
        <a href="/works/originals">Original Works</a>

        {work.data.seriesTitle && work.data.seriesSlug && (
          <>
            {" / "}
            <a href={`/works/originals/${work.data.seriesSlug}`}>
              {work.data.seriesTitle}
            </a>
          </>
        )}
      </>
    )}

    {" / "}
    <span>{work.data.chapterTitle ?? work.data.title}</span>
  </p>

  <article class="chapter">
    <header class="chapter-header">
      {work.data.seriesTitle && (
        <p class="series-title">{work.data.seriesTitle}</p>
      )}

      <h2 class="chapter-title">
        {work.data.workType === "series" && work.data.chapterNumber
          ? `Chapter ${work.data.chapterNumber}: ${work.data.chapterTitle ?? work.data.title}`
          : work.data.title}
      </h2>

      <div class="fandom-list">
        {work.data.fandoms.map((fandom, index) => (
          <a class="fandom-pill" href={`/works/${work.data.fandomSlug[index]}`}>
            {fandom.toUpperCase()}
          </a>
        ))}

        {work.data.category === "crossover" && (
          <span class="fandom-pill crossover-pill">CROSSOVER</span>
        )}
      </div>

      <p class="chapter-summary">{work.data.summary}</p>

      <p class="word-count">Word Count: {work.data.wordCount}</p>

      {work.data.contentWarnings && (
        <p class="content-warnings">CW: {work.data.contentWarnings}</p>
      )}

      {work.data.authorsNote && (
  <div class="authors-note">
    {work.data.authorsNote.split("\n\n").map((para) => (
      <p>{para}</p>
    ))}
  </div>
)}

      {work.data.seriesTitle && work.data.seriesSlug && work.data.category === "fanfiction" && (
        <div class="series-index-link">
          <a href={`/works/${work.data.fandomSlug[0]}/${work.data.seriesSlug}`}>
            {work.data.seriesTitle}: Chapter Index
          </a>
        </div>
      )}

      {work.data.seriesTitle && work.data.seriesSlug && work.data.category === "crossover" && (
        <div class="series-index-link">
          <a href={`/works/crossovers/${work.data.seriesSlug}`}>
            {work.data.seriesTitle}: Chapter Index
          </a>
        </div>
      )}

      {work.data.seriesTitle && work.data.seriesSlug && work.data.category === "original" && (
        <div class="series-index-link">
          <a href={`/works/originals/${work.data.seriesSlug}`}>
            {work.data.seriesTitle}: Chapter Index
          </a>
        </div>
      )}
    </header>

    <hr />

    <Content />

    {(previousChapter || nextChapter) && (
      <>
        <hr />

        <nav aria-label="Chapter navigation">
          <div class="chapter-nav">
            <div>
              {previousChapter && (
                <a href={`/works/read/${previousChapter.id}`}>
                  ← Previous: {previousChapter.data.chapterTitle ?? previousChapter.data.title}
                </a>
              )}
            </div>

            <div class="chapter-nav-next">
              {nextChapter && (
                <a href={`/works/read/${nextChapter.id}`}>
                  Next: {nextChapter.data.chapterTitle ?? nextChapter.data.title} →
                </a>
              )}
            </div>
          </div>
        </nav>
      </>
    )}
  </article>
</BaseLayout>

<style>
  .chapter {
    font-size: 1.1rem;
    max-width: 70ch;
    margin: 0 auto;
  }

  .chapter-header {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
  }

  .series-title {
    margin: 0;
    font-size: 2rem;
    line-height: 1.2;
  }

  .chapter-title {
    margin: 0;
    font-size: 1.5rem;
    line-height: 1.3;
  }

  .fandom-list {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
  margin: 0.25rem 0 0.5rem 0;
}

.fandom-pill {
  display: inline-block;
  padding: 0.25rem 0.7rem;
  border: 1px solid #5a4a2a;
  border-radius: 999px;
  background: #1a1a1a;
  color: #d4b26a;
  font-size: 0.9rem;
  letter-spacing: 0.04em;
  text-decoration: none;
  transition: background 0.15s ease, border-color 0.15s ease, color 0.15s ease;
}

.fandom-pill:hover {
  background: #222;
  border-color: #7a6336;
  color: #e5c27a;
  text-decoration: none;
}

.crossover-pill {
  border-color: #4f3d5e;
  color: #c9a7e8;
}

  .chapter-summary,
  .content-warnings {
    margin: 0;
    font-style: italic;
  }

  .authors-note {
  font-size: 0.9rem;
  font-style: italic;
  opacity: 0.9;
  margin-top: 1rem;
}

.authors-note p {
  margin: 0 0 0.75rem 0;
}

.authors-note p:last-child {
  margin-bottom: 0;
}

  .word-count {
    margin: 0;
  }

  .chapter p {
    margin: 1.10rem 0;
  }

  .chapter hr {
    margin: 2rem 0;
  }

  .chapter-nav {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    margin-top: 2rem;
    padding-top: 1rem;
    border-top: 1px solid #2a2a2a;
  }

  .chapter-nav > div {
    flex: 1;
  }

  .chapter-nav-next {
    text-align: right;
  }

  .chapter-nav a {
    font-size: 0.95rem;
  }

  .series-index-link {
  text-align: center;
  margin-bottom: 1.5rem;
}

.series-index-link a {
  font-size: 0.9rem;
  opacity: 0.8;
}

.series-index-link a:hover {
  opacity: 1;
}

  .breadcrumb {
  margin: 0 0 1rem 0;
  font-size: 0.95rem;
  opacity: 0.8;
}

.breadcrumb a {
  text-decoration: none;
}

.authors-note img {
    display: inline-block;
    vertical-align: middle;
    margin-left: 0.5rem;
    height: 31px;
    position: relative;
    top: -1px; 
  }
</style>